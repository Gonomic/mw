# Synology SSO Configuration
# Zie ook: NAS_PROD_DEPLOY_CHECKLIST.md
SYNOLOGY_OIDC_DISCOVERY_URL=https://your-synology-domain/webman/sso/.well-known/openid-configuration
SYNOLOGY_CLIENT_ID=your-client-id
SYNOLOGY_OIDC_VERIFY_SSL=false

# Synology LDAP Configuration (for role lookup)
SYNOLOGY_LDAP_URL=ldaps://192.168.1.10:636
SYNOLOGY_LDAP_BIND_DN=uid=root,cn=users,dc=dekknet,dc=com
SYNOLOGY_LDAP_BIND_PASSWORD=your-ldap-bind-password
SYNOLOGY_LDAP_GROUP_ADMIN_DN=cn=Familiez_Admin,cn=groups,dc=dekknet,dc=com
SYNOLOGY_LDAP_GROUP_USER_DN=cn=Familiez_Users,cn=groups,dc=dekknet,dc=com
SYNOLOGY_LDAP_MEMBER_DN_TEMPLATE=uid={username},cn=users,dc=dekknet,dc=com
SYNOLOGY_LDAP_GROUP_ADMIN_NAME=Familiez_Admin
SYNOLOGY_LDAP_GROUP_USER_NAME=Familiez_Users
SYNOLOGY_LDAP_GROUP_MEMBER_ATTRIBUTES=member,uniqueMember,memberUid
SYNOLOGY_STRIP_USERNAME_DOMAIN=true
SYNOLOGY_LDAPTLS_REQCERT=never
SYNOLOGY_LDAP_TIMEOUT=8

# Database Configuration
DATABASE_URL=mysql+pymysql://user:password@host:3306/database

# File Storage Configuration
# Environment: 'development' or 'production'
STORAGE_ENVIRONMENT=development
# Base path for file storage
# Development: /home/frans/Documenten/Dev/Familiez/BESTANDEN
# Production: /docker/familiez/media
STORAGE_BASE_PATH=/home/frans/Documenten/Dev/Familiez/BESTANDEN
# Maximum file upload size in bytes (default: 52428800 = 50MB)
MAX_FILE_UPLOAD_SIZE=52428800
